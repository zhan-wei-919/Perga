{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Perga",
  "version": "0.1.0",
  "identifier": "io.perga.app",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": {
      "script": "pnpm dev",
      "cwd": "../../web"
    },
    "beforeBuildCommand": {
      "script": "pnpm build",
      "cwd": "../../web"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Perga",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Perga 终端",
    "longDescription": "Perga 是以 Web 前端为主、Rust 后端接管 PTY 与 SSH 的新形态终端。"
  }
}
